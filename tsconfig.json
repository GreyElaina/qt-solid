{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "preserve",
    "jsxImportSource": "@qt-solid/solid",
    "allowJs": true,
    "types": ["node"],
    "paths": {
      "@qt-solid/core": ["./packages/core/native/types.d.ts"],
      "@qt-solid/core/native": ["./packages/core/native/index.d.ts"],
      "@qt-solid/solid": ["./packages/solid/src/index.ts"],
      "@qt-solid/solid/rolldown": ["./packages/solid/src/build/rolldown.ts"],
      "@qt-solid/solid/vite": ["./packages/solid/src/build/vite.ts"],
      "@qt-solid/solid/hmr": ["./packages/solid/src/entry/hmr.ts"],
      "@qt-solid/solid/bootstrap": ["./packages/solid/src/entry/bootstrap.ts"],
      "@qt-solid/solid/compiler": ["./packages/solid/src/build/compiler.ts"],
      "@qt-solid/solid/compiler-rt": ["./packages/solid/src/compiler-rt.ts"],
      "@qt-solid/solid/jsx-runtime": ["./packages/solid/src/jsx-runtime.d.ts"],
      "@qt-solid/solid/jsx-dev-runtime": ["./packages/solid/src/jsx-runtime.d.ts"],
      "@qt-solid/solid/preview": ["./packages/solid/src/preview/index.ts"],
      "@qt-solid/solid/preview/config": ["./packages/solid/src/preview/config.ts"],
      "@qt-solid/solid/preview/runtime": ["./packages/solid/src/preview/preview-runtime.ts"],
      "@qt-solid/solid/preview/shell": ["./packages/solid/src/preview/preview-shell.tsx"],
      "@qt-solid/fluent": ["./packages/fluent/src/index.ts"]
    },

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "exclude": [
    "node_modules",
    "packages/figma-codegen",
    "packages/figma-plugin",
    "**/dist",
    "**/dist-sea"
  ]
}
