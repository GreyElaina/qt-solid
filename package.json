{
  "name": "qt-solid-spike",
  "type": "module",
  "private": true,
  "workspaces": [
    "examples/*",
    "packages/*"
  ],
  "scripts": {
    "build:native": "napi build --manifest-path packages/core/crates/native/Cargo.toml --platform --esm --output-dir packages/core/native --js index.js --dts index.d.ts",
    "build:native:release": "napi build --manifest-path packages/core/crates/native/Cargo.toml --platform --esm --output-dir packages/core/native --js index.js --dts index.d.ts --release",
    "check:native": "cargo check -p native",
    "typecheck": "tsgo --noEmit",
    "pretypecheck": "npm run build:native",
    "pretest": "npm run build:native",
    "pretest:native": "npm run build:native",
    "test": "vitest run",
    "test:native": "vitest run ./test/rolldown-app-entry.test.ts ./test/solid-renderer-native.test.ts ./test/solid-renderer-native-tsx.test.ts ./test/solid-renderer-native-intrinsic-tsx.test.ts ./test/solid-renderer-motion-tsx.test.ts",
    "example:rendering-gallery": "npm --workspace=@qt-solid-spike/example-rendering-gallery run run"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@napi-rs/cli": "^3.6.0",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "babel-preset-solid": "^1.9.12",
    "postject": "^1.0.0-alpha.6",
    "rolldown": "^1.0.0-rc.14",
    "solid-refresh": "^0.7.8",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@qt-solid/core": "workspace:*",
    "@qt-solid/solid": "workspace:*",
    "@types/node": "^25.5.2",
    "solid-js": "^1.9.12",
    "ws": "^8.20.0"
  }
}
