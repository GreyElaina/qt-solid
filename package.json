{
  "name": "qt-solid-spike",
  "type": "module",
  "private": true,
  "workspaces": [
    "examples/*",
    "packages/*"
  ],
  "scripts": {
    "generate:bindings": "cargo check -p qt-solid-core-widgets -p qt-solid-example-widgets && cargo run -p native --bin generate_ts_bindings",
    "build:native": "napi build --manifest-path packages/core-native/crates/native/Cargo.toml --platform --esm --output-dir packages/core/native --js generated.js --dts generated.d.ts",
    "build:native:example-widgets": "napi build --manifest-path packages/example-widgets/Cargo.toml --platform --esm --output-dir packages/example-widgets/native --js generated.js --dts generated.d.ts",
    "build:native:release": "napi build --manifest-path packages/core-native/crates/native/Cargo.toml --platform --esm --output-dir packages/core/native --js generated.js --dts generated.d.ts --release",
    "check:native": "cargo check -p native",
    "example:counter": "npm --workspace=@qt-solid-spike/example-counter run run",
    "example:counter:build": "npm --workspace=@qt-solid-spike/example-counter run build",
    "example:counter:dev": "npm --workspace=@qt-solid-spike/example-counter run dev",
    "example:counter:start": "npm --workspace=@qt-solid-spike/example-counter run start",
    "example:counter:sea": "npm --workspace=@qt-solid-spike/example-counter run sea",
    "example:counter:app": "npm --workspace=@qt-solid-spike/example-counter run app",
    "example:counter:devtools": "npm --workspace=@qt-solid-spike/example-counter run devtools",
    "example:calculator": "npm --workspace=@qt-solid-spike/example-calculator run run",
    "example:calculator:build": "npm --workspace=@qt-solid-spike/example-calculator run build",
    "example:calculator:start": "npm --workspace=@qt-solid-spike/example-calculator run start",
    "example:calculator:dev": "npm --workspace=@qt-solid-spike/example-calculator run dev",
    "example:calculator:app": "npm --workspace=@qt-solid-spike/example-calculator run app",
    "example:calculator:devtools": "npm --workspace=@qt-solid-spike/example-calculator run devtools",
    "typecheck": "tsc --noEmit",
    "pretypecheck": "npm run generate:bindings",
    "pretest": "npm run generate:bindings && npm run build:native && npm run build:native:example-widgets",
    "pretest:native": "npm run generate:bindings && npm run build:native && npm run build:native:example-widgets",
    "test": "vitest run",
    "test:native": "vitest run ./test/native-lifecycle.test.ts ./test/rolldown-app-entry.test.ts ./test/solid-renderer-native.test.ts ./test/solid-renderer-native-tsx.test.ts ./test/solid-renderer-native-intrinsic-tsx.test.ts",
    "example:spin_triangle": "npm --workspace=@qt-solid-spike/example-spin-triangle run run",
    "example:spin_triangle:build": "npm --workspace=@qt-solid-spike/example-spin-triangle run build",
    "example:spin_triangle:start": "npm --workspace=@qt-solid-spike/example-spin-triangle run start",
    "example:spin_triangle:sea": "npm --workspace=@qt-solid-spike/example-spin-triangle run sea",
    "example:spin_triangle:dev": "npm --workspace=@qt-solid-spike/example-spin-triangle run dev",
    "example:spin_triangle:devtools": "npm --workspace=@qt-solid-spike/example-spin-triangle run devtools",
    "example:spin_trinagle": "npm run example:spin_triangle"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@napi-rs/cli": "^3.6.0",
    "@types/ws": "^8.18.1",
    "babel-preset-solid": "^1.9.12",
    "postject": "^1.0.0-alpha.6",
    "rolldown": "^1.0.0-rc.14",
    "solid-refresh": "^0.7.8",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@qt-solid/core": "workspace:*",
    "@qt-solid/core-widgets": "workspace:*",
    "@qt-solid/example-widgets": "workspace:*",
    "@qt-solid/solid": "workspace:*",
    "@types/node": "^25.5.2",
    "solid-js": "^1.9.12",
    "ws": "^8.20.0"
  }
}
