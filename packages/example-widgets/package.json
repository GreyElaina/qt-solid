{
  "name": "@qt-solid/example-widgets",
  "version": "0.0.0",
  "main": "src/index.ts",
  "license": "ISC",
  "type": "module",
  "private": false,
  "scripts": {
    "build:native": "napi build --manifest-path ./Cargo.toml --platform --esm --output-dir ./native --js generated.js --dts generated.d.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./qt-intrinsics": {
      "types": "./src/qt-intrinsics.ts",
      "default": "./src/qt-intrinsics.ts"
    },
    "./native": {
      "types": "./src/native.d.ts",
      "default": "./src/native.ts"
    },
    "./widget-library": {
      "types": "./src/widget-library.ts",
      "default": "./src/widget-library.ts"
    }
  },
  "dependencies": {
    "@qt-solid/core": "workspace:*",
    "@qt-solid/solid": "workspace:*",
    "solid-js": "^1.9.12"
  }
}
